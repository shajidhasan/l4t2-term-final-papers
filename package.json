		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.2",
		"vite": "^8.0.8"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	},
	"dependencies": {
		"@lucide/svelte": "^1.8.0",
		"katex": "^0.16.45",
		"markdown-it": "^14.1.1",
		"minisearch": "^7.2.0",
		"svelte-persisted-state": "^1.4.0"
